{
  "name": "print-agent",
  "version": "1.0.0",
  "description": "Silent Print Agent - Local REST API for POS printing",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "nodemon --exec electron .",
    "build": "electron-builder --win",
    "test": "jest",
    "lint": "eslint src/**/*.js"
  },
  "keywords": [
    "print",
    "pos",
    "thermal",
    "label",
    "escpos",
    "tspl",
    "zpl"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "async": "^3.2.5",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dbffile": "^1.12.0",
    "dotenv": "^16.3.1",
    "escpos": "^3.0.0-alpha.6",
    "escpos-usb": "^3.0.0-alpha.4",
    "express": "^4.18.2",
    "joi": "^17.11.0",
    "nanoid": "^3.3.7",
    "node-printer": "^1.0.1",
    "pdf-to-printer": "^5.6.0",
    "puppeteer": "^21.6.0",
    "selfsigned": "^2.4.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2"
  },
  "build": {
    "appId": "com.printagent.app",
    "productName": "Print Agent",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    },
    "files": [
      "src/**/*",
      "config/**/*",
      "assets/**/*",
      "public/**/*",
      "node_modules/**/*"
    ]
  }
}
